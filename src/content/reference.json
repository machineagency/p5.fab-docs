    "returns": null,
    "examples": [
      "function fabDraw() {\n  fab.moveExtrude(50, 50, 0.2, 1500);\n  fab.moveRetract(100, 100, 0.2, 3000); // travel without stringing\n  fab.moveExtrude(150, 50, 0.2, 1500);\n}"
    ]
