        "name": "e",
        "type": "number | null",
        "description": "Extrusion amount in mm. Calculated automatically if null.",
        "optional": true,
        "defaultvalue": null
      },
      {
        "name": "multiplier",
        "type": "boolean",
        "description": "If true, treat `e` as a multiplier on the auto-calculated extrusion.",
        "optional": true,
        "defaultvalue": false
      }
    ],
    "returns": null,
    "examples": [
      "function setup() {\n  createCanvas(windowWidth, windowHeight, WEBGL);\n}\n\nfunction fabDraw() {\n  fab.autoHome();\n  fab.moveExtrude(100, 100, 0);\n}\n\nfunction draw() {\n  background(255);\n  fab.render();\n}"
    ]
  },
  {
    "name": "moveRetract",
    "description": "Move to an absolute position with a filament retraction, z-hop, and re-prime.\nUse this to travel between disconnected extrusion paths without stringing.",
    "params": [
