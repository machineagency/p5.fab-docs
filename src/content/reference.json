[
  {
    "name": "createFab",
    "description": "Creates and returns the global `fab` object. Call this once in `setup()`.\n\nCalling it multiple times returns the same\ninstance, preserving any open serial connection across hot-reloads.\n\n**Hot-reload behavior:** In the copypastes.xyz editor, `setup()` re-runs\nevery time you run your sketch. This means changes to `setup()` (e.g.\n`setPrinter()`, canvas size) take effect immediately. However, avoid\ncreating p5.js DOM elements (`createButton()`, `createSlider()`, etc.) in\n`setup()`: they will be duplicated on each run.",
    "params": [],
    "returns": {
      "type": "Fab",
      "description": "The global fab instance."
    },
    "examples": [
      "function setup() {\n  fab = createFab();\n  fab.setPrinter('ender3');\n}"
    ]
  },
  {
    "name": "setPrinter",
    "description": "Configure the fab instance for a specific printer preset, with optional overrides.",
    "params": [
      {
        "name": "name",
        "type": "string",
        "description": "Printer preset name (e.g. `'ender3'`, `'prusa'`).",
        "optional": false,
        "defaultvalue": null
      },
      {
        "name": "overrides",
        "type": "Object",
        "description": "Optional settings to override the preset (e.g. `{ nozzleDiameter: 0.4 }`).",
        "optional": true,
        "defaultvalue": "{}"
      }
    ],
    "returns": null,
    "examples": [
      "function setup() {\n  fab = new Fab();\n  fab.setPrinter('ender3', { nozzleDiameter: 0.4 });\n}"
    ]
  },
  {
    "name": "render",
    "description": "Render a 3D preview of the planned toolpath. Call this inside a WEBGL p5.js `draw()` loop.",
    "params": [],
    "returns": null,
    "examples": [
      "function draw() {\n  background(255);\n  fab.render();\n}"
    ]
  },
  {
    "name": "setCameraView",
