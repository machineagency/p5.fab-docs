---
import DocsLayout from '../../layouts/DocsLayout.astro';
import reference from '../../content/reference.json';
import virtualMethods from '../../content/virtual-methods.json';

const EDITOR_URL = import.meta.env.PUBLIC_EDITOR_URL ?? 'http://localhost:5173';

export function getStaticPaths() {
  return reference.map(method => ({
    params: { method: method.name },
    props: { method },
  }));
}

const { method } = Astro.props;
const isProperty = method.kind === 'property';

// Entries are fab instance methods (fab.circle(...)) except user-defined lifecycle
// globals (setup/draw/fabDraw, from virtual-methods.json) and the createFab() constructor,
// which are called globally and so render without the fab. prefix.
const globalFns = new Set([...virtualMethods.map(v => v.name), 'createFab']);
const receiver = globalFns.has(method.name) ? '' : 'fab.';
const signature = `${receiver}${method.name}(${method.params
  .map(p => (p.optional ? `[${p.name}]` : p.name))
  .join(', ')})`;

const md = (text) => (text ?? '')
  .replace(/`([^`]+)`/g, '<code>$1</code>')
  .replace(/\{@link\s+(\S+)(?:\s+([^}]*))?\}/g, (_, url, label) =>
    `<a href="${url}">${(label ?? url).trim()}</a>`);
---

<DocsLayout title={`${method.name}${isProperty ? '' : '()'} — p5.fab reference`}>
  <h1>{method.name}{isProperty ? '' : '()'}</h1>

  {method.readonly && <p class="property-badge">Read-only</p>}

  {method.description.split('\n\n').map(para => {
    const t = para.trim();
    if (t.startsWith('```')) {
      const code = t.replace(/^```[^\n]*\n?/, '').replace(/\n?```$/, '');
      return <pre><code>{code}</code></pre>;
    }
    return <p set:html={md(t)} />;
  })}

  {!isProperty && method.params.length > 0 && (
    <section>
      <h2>Parameters</h2>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {method.params.map(p => (
            <tr>
              <td><code>{p.name}{p.optional ? '?' : ''}</code></td>
              <td><code>{p.type}</code></td>
              <td set:html={md(p.description) + (p.defaultvalue !== null ? ` Default: <code>${p.defaultvalue}</code>.` : '')} />
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {isProperty && method.returns && (
    <section>
      <h2>Type</h2>
      <p><code>{method.returns.type}</code></p>
    </section>
  )}

  {!isProperty && method.returns && (
    <section>
      <h2>Returns</h2>
      <p><code>{method.returns.type}</code> — <span set:html={md(method.returns.description)} /></p>
    </section>
  )}

  {method.examples.length > 0 && (
    <section>
      <h2>Examples</h2>
      {method.examples.map(ex => (
        <iframe
          src={`${EDITOR_URL}/embed?code=${encodeURIComponent(ex)}`}
          title={`${method.name}${isProperty ? '' : '()'} example`}
          class="embed-frame"
          sandbox="allow-scripts allow-downloads allow-same-origin"
          allow="clipboard-write"
        ></iframe>
      ))}
    </section>
  )}

  {!isProperty && (
    <section>
      <h2>Syntax</h2>
      <div class="syntax-block">
        <pre><code>{signature}</code></pre>
        <button
          class="copy-btn"
          type="button"
          data-copy={signature}
          aria-label="Copy syntax to clipboard"
        >Copy</button>
      </div>
    </section>
  )}
</DocsLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy ?? '');
        const prev = btn.textContent;
        btn.textContent = '✓ Copied';
        setTimeout(() => {
          btn.textContent = prev;
        }, 1200);
      } catch {
        /* clipboard unavailable (e.g. insecure context) */
      }
    });
  });
</script>

<style>
  .property-badge {
    display: inline-block;
    background: #f0f0f0;
    border: 1px solid #ccc;
    border-radius: 3px;
    padding: 1px 8px;
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .syntax-block {
    position: relative;
  }
  .syntax-block pre {
    margin: 0;
    padding-right: 4.5rem; /* keep the signature clear of the button */
  }
  /* Matches the embed editor's Copy button exactly. That button is <button class="icon-btn">
     inside .toolbar, so its computed style is dominated by `.toolbar button` (font-size 0.8rem,
     padding 0.2rem 0.6rem, 1px solid black) overriding `.icon-btn`, plus the global button rule
     (border-radius 4px, letter-spacing 1.1px, font-weight 400) and the orange :hover — all in
     the p5.fab-website repo (src/routes/embed/+page.svelte + src/app.css). font-family is
     hard-set to monospace: the website has no --font-mono (falls back to monospace) while the
     docs --font-mono is Roboto Mono. Only the positioning is docs-specific. Kept in sync by hand
     (separate repos + cross-origin iframe). */
  .copy-btn {
    position: absolute;
    top: 50%;
    right: 0.5rem;
    transform: translateY(-50%);
    font-family: monospace;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 1.1px;
    padding: 0.2rem 0.6rem;
    border: 1px solid black;
    border-radius: 4px;
    background: white;
    color: #555;
    cursor: pointer;
  }
  .copy-btn:hover {
    background: #ff6700;
    color: white;
  }
</style>
